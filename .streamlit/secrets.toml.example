# Snowflake read-only credentials — users bring their own OpenAI key via the UI
[snowflake]
account   = "YOUR_ACCOUNT_IDENTIFIER"   # e.g. xy12345.us-east-1 (no .snowflakecomputing.com)
user      = "CHAT_WH_USER"
password  = "YOUR_PASSWORD"
warehouse = "CHAT_WH"
database  = "INSURANCE_DB"
schema    = "CLAIMS"
role      = "CHAT_WH_ROLE"
